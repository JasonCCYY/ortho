{
  "rewrites": [
    { "source": "/clinic/js/:path*", "destination": "/public/clinic/js/:path*" },
    { "source": "/clinic/index.html","destination": "/public/clinic/index.html" },
    { "source": "/clinic",           "destination": "/public/clinic/index.html" },
    { "source": "/:path*",           "destination": "/public/:path*" }
  ]
}
